# ============================================================================ #
def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--model_name", type=str, default="meta-llama/Meta-Llama-3-8B")
    parser.add_argument("--data_dir", type=str, default="data", 
                        help="Directory containing Hugging Face DatasetDict")
    parser.add_argument("--seq_length", type=int, default=2048)
    parser.add_argument("--global_batch_size", type=int, default=16)
    parser.add_argument("--micro_batch_size", type=int, default=1)
    
    # -------------------------------------------------------------
    # Hyperparameters from Image (Exp 1)
    # -------------------------------------------------------------
    parser.add_argument("--lr", type=float, default=0.0005)              # Muon LR
    parser.add_argument("--weight_decay", type=float, default=0.2)       # Muon WD
    parser.add_argument("--momentum", type=float, default=0.95)          # Muon Momentum
    parser.add_argument("--adam_lr", type=float, default=0.0002)         # AdamW LR
    parser.add_argument("--adam_weight_decay", type=float, default=0.01) # AdamW WD
    parser.add_argument("--adam_beta1", type=float, default=0.9)         # AdamW Beta1 (Momentum)
    parser.add_argument("--lora_rank", type=int, default=16)             # LoRA Rank
    parser.add_argument("--lora_dropout", type=float, default=0.05)      # LoRA Dropout
    
    parser.add_argument("--max_steps", type=int, default=150)
    parser.add_argument("--devices", type=int, default=1)
    args = parser.parse_args()

    torch.set_float32_matmul_precision("high")

    # W&B Logger setup
    wandb_logger = WandbLogger(project="llama3-lora-muon", name="Exp-1-Vanilla-LoRA")

    # 1. Tokenizer
    tokenizer = AutoTokenizer.from_pretrained(args.model_name)
    if tokenizer.pad_token is None:
        tokenizer.pad_token = tokenizer.eos_token

    # 2. LoRA config (HuggingFace PEFT)
    lora_config = LoraConfig(
        task_type=TaskType.CAUSAL_LM,
        r=args.lora_rank,
        lora_alpha=128, 
        lora_dropout=args.lora_dropout,
        target_modules=["q_proj", "k_proj", "v_proj",
                        "o_proj", "gate_proj", "up_proj", "down_proj"],
        bias="none",
    )

    # 3. Lightning module
    module = LlamaLoRALightningModule(
        model_name=args.model_name,
        lora_config=lora_config,
        lr=args.lr,
        adam_w_lr=args.adam_lr,
        weight_decay=args.weight_decay,
        adam_w_weight_decay=args.adam_weight_decay,
        momentum=args.momentum,
        adam_beta1=args.adam_beta1
    )

    # 4. Data
    dataset = TextDataset(tokenizer, args.data_dir, split="train", seq_length=args.seq_length)
    loader = DataLoader(
        dataset,
        batch_size=args.micro_batch_size,
        shuffle=True,
        num_workers=4,
        pin_memory=True,
    )

    # 5. Trainer
    strategy = DDPStrategy(find_unused_parameters=False) if args.devices > 1 else "auto"
    trainer = pl.Trainer(
        logger=wandb_logger,            # Pass W&B to trainer
        devices=args.devices,
        num_nodes=1,
        max_steps=args.max_steps,
        accelerator="gpu",
        strategy=strategy,
        precision="bf16-true",          # native torch bf16
        log_every_n_steps=1,
        gradient_clip_val=1.0,
        accumulate_grad_batches=args.global_batch_size // args.micro_batch_size,
    )

    print(f"\n{'='*70}")
    print(f"[START] Exp 1: Llama3-8B Vanilla LoRA + Muon (W&B Active)")
    print(f"{'='*70}\n")

    trainer.fit(module, train_dataloaders=loader)


if __name__ == "__main__":
    main()
